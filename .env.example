# .env 

# General project settings
PROJECT_NAME=the-conversion-ground-truth
PYTHON_VERSION=3.11.9

# HuggingFace Hub (for dataset/model upload)
HF_TOKEN=your_huggingface_access_token_here

# Weights & Biases (for experiment tracking)
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=tenacious-judge
WANDB_ENTITY=your_wandb_username_or_team

# Logging
LOG_LEVEL=INFO

# Optional: Database or storage (if you plan to persist results)
DB_URL=postgresql://user:password@localhost:5432/conversion_engine

# Optional: Email/Notification integration
SMTP_SERVER=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_email_username
SMTP_PASSWORD=your_email_password

# Optional: Cloud storage (if pushing artifacts to S3 or Azure)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=tenacious-conversion-engine

# Random seed for reproducibility
SEED=42
